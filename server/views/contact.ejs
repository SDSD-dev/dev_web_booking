<%- include('partials/header.ejs') %>
<main>
  <section>
    <form action="/contact" method="POST" class="compact-search-form" novalidate>
      <h3>Formulaire de contact</h3>
      <div class="form-group">
      <label for="nom" >Nom (obligatoire) :</label>
      <input type="text" id="nom" name="nom" class="rounded-input" required />
      <label for="prenom">Prénom (obligatoire) :</label>
      <input type="text" id="prenom" name="prenom" class="rounded-input" required />
        <label for="email">Email (obligatoire) :</label>
        <input type="email" id="email" name="email" class="rounded-input" required />
        <label for="phone">Téléphone :</label>
        <input type="tel" id="phone" name="phone" class="rounded-input" required />
        <label for="message">Message (obligatoire) :</label>
        <textarea id="message" name="message" class="rounded-input" required></textarea>
        <label class="custom-checkbox">
        <input type="checkbox" name="consent_public" value="yes" required>
          <span> Je consens à la publication de mon message.</span>
        </label>
        <div><button type="submit" class="btn-primary rounded-btn">Envoyer</button></div>
      </div>
    </form>
  </section>
</main>
<%- include('partials/footer.ejs') %>
