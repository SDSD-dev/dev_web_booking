<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact - Mon Site</title>
    <link rel="stylesheet" href="css/style.css" />
  </head>
  <body>
    <header>
      <h1>Contact</h1>
      <nav>
        <a href="/">Accueil</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      <section>
        <img
          style="max-width: 10%"
          src="img/<%= imageName %>"
          alt="Image dynamique"
          class="responsive-img"
        />
        <h2>Formulaire de contact</h2>
        <form action="/contact_form" method="POST" novalidate>
          <label for="nom">Nom (obligatoire) :</label>
          <input type="text" id="nom" name="nom" required />
          <label for="nom">Prenom (obligatoire) :</label>
          <input type="text" id="prenom" name="prenom" required />
          <label for="email">Email (obligatoire) :</label>
          <input type="email" id="email" name="email" required />
          <label for="email">Téléphone :</label>
          <input type="phone" id="phone" name="phone" required />
          <label for="message">Message (obligatoire) :</label>
          <textarea id="message" name="message" required></textarea>
          <label
            ><input
              type="checkbox"
              name="consent_public"
              value="yes"
              required
            />
            Je consens à la publication de mon message.</label
          >
          <div><button type="submit">Envoyer</button></div>
        </form>
      </section>
      <section>
        <h2>Une autre image</h2>
        <p>Ceci est une page provisoire pour tester Node.js.</p>
        <img
          src="img_rooms/img_hotel_0009.jpg"
          alt="chambre_hotel"
          class="responsive-img"
        />
        <br />
      </section>
    </main>
    <footer>
      <p>© 2025 Mon Site de test Node.JS + express</p>
    </footer>
  </body>
</html>
