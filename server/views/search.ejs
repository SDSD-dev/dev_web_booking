<%- include('partials/header.ejs') %>

<main> <% if (searchList && searchList.length > 0) { %>

    <section class="search-results-grid">
      <div class="results-header">
        <h1 class="page-title"><%= searchList.length %> établissements trouvés.</h1>
      </div>
      <% searchList.forEach(function(hotel) { %>
        
        <article class="horizontal-hotel-card">
          
          <div class="card-image-side">
            <img src="<%= hotel.main_image_url %>" alt="Image de l'hôtel <%= hotel.name %>">
          </div>

          <div class="card-content-side">
  
            <div class="card-header">
              <div class="header-top-row">
                <h2 class="hotel-name"><strong><%= hotel.name %></strong></h2>
              </div>
              <p class="hotel-location"><svg class="inline-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg> <%= hotel.city %></p>
              <div class="stars-container" style="--rating: <%= parseFloat(hotel.average_rating || 0).toFixed(1) %>;" aria-label="Note de <%= hotel.average_rating || 0 %> sur 5">
                <span class="review-count">(<%= hotel.review_count || 0 %>)</span>
              </div>
            </div>
            <ul class="hotel-details-list">
              <li>Types de chambres : <%= hotel.nb_types_chambres %></li>
              <li>Capacité max : <%= hotel.capacite_max %> personnes</li>
            </ul>
            <div><%= hotel.description_hotel %></div>
            <div class="amenities-row">
              <% if (hotel.wifi) { %>
                <span class="amenity-badge" title="Wi-Fi Gratuit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" /></svg>
                </span>
              <% } %>
              
              <% if (hotel.piscine) { %>
                <span class="amenity-badge" title="Piscine">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg> </span>
              <% } %>

              <% if (hotel.animaux) { %>
                <span class="amenity-badge" title="Animaux acceptés">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/><path d="M12 12.5c-1.5 0-2.5 1-2.5 2.5s1 2.5 2.5 2.5 2.5-1 2.5-2.5-1-2.5-2.5-2.5z"/><path d="M7.5 8.5A1.5 1.5 0 1 0 6 7a1.5 1.5 0 0 0 1.5 1.5z"/><path d="M16.5 8.5A1.5 1.5 0 1 0 18 7a1.5 1.5 0 0 0-1.5 1.5z"/></svg>
                </span>
              <% } %>
            </div>

            <div class="card-footer">
              <div class="price-group">
                <span class="price-label">Prix le plus bas</span>
                <span class="card-price"><%= hotel.prix_base %> €</span>
              </div>
              
              <a href="/hotel/<%= hotel.id_hotel %>?date_debut=<%= searchParams.date_debut %>&date_fin=<%= searchParams.date_fin %>&adultes=<%= searchParams.adultes %>" class="card-button btn-voir">
                Voir l'hôtel
              </a>
            </div>

          </div>

        </article>
        <% }); %>
    
    </section>

  <% } else { %>
    <div class="no-results container">
      <p>Désolé, aucune chambre ne correspond à vos critères de recherche. :)</p>
    </div>
  <% } %>

</main>

<%- include('partials/footer.ejs') %>